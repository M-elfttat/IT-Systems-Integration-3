{
  "info": {
    "name": "Doctor Appointment Booking System - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:5000" },
    { "key": "patientToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "doctorId", "value": "1" },
    { "key": "appointmentId", "value": "1" }
  ],
  "item": [
    {
      "name": "Register Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Test Patient\",\n  \"email\": \"patient1@example.com\",\n  \"phone\": \"+97412345678\",\n  \"password\": \"Patient123\"\n}"
        }
      }
    },
    {
      "name": "Login Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"patient1@example.com\",\n  \"password\": \"Patient123\"\n}"
        }
      }
    },
    {
      "name": "Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@clinic.com\",\n  \"password\": \"Admin123\"\n}"
        }
      }
    },
    {
      "name": "Get Doctors",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors"
      }
    },
    {
      "name": "Book Appointment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{patientToken}}" }
        ],
        "url": "{{baseUrl}}/api/appointments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"doctor_id\": {{doctorId}},\n  \"appointment_date\": \"2026-04-15\",\n  \"appointment_time\": \"10:30:00\",\n  \"notes\": \"Routine follow-up\"\n}"
        }
      }
    },
    {
      "name": "Get Patient Appointments",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
        "url": "{{baseUrl}}/api/appointments"
      }
    },
    {
      "name": "Get Admin Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/dashboard"
      }
    },
    {
      "name": "Add Doctor",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/doctors",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"Dr. Layla Salem\",\n  \"specialization\": \"Neurology\",\n  \"availability\": \"Sun-Thu, 1:00 PM - 5:00 PM\",\n  \"email\": \"layla.salem@clinic.com\",\n  \"phone\": \"+97450001111\"\n}"
        }
      }
    },
    {
      "name": "Get Admin Appointments",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/appointments"
      }
    },
    {
      "name": "Update Appointment Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/appointments/{{appointmentId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"Completed\"\n}"
        }
      }
    }
  ]
}
